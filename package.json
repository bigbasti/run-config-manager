{
  "name": "run-config-manager",
  "displayName": "Run Configuration Manager",
  "description": "IntelliJ-style run configurations for VS Code (npm, Angular, Node.js).",
  "version": "0.1.0",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "runConfigManager",
          "title": "Run Configurations",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "runConfigManager": [
        {
          "id": "runConfigurations",
          "name": "Configurations",
          "contextualTitle": "Run Configurations"
        }
      ]
    },
    "commands": [
      { "command": "runConfig.add", "title": "Add Run Configuration", "icon": "$(add)" },
      { "command": "runConfig.autoCreate", "title": "Auto-create Configurations", "icon": "$(sparkle)" },
      { "command": "runConfig.stopAll", "title": "Stop All Running", "icon": "$(stop-circle)" },
      { "command": "runConfig.refresh", "title": "Refresh", "icon": "$(refresh)" },
      { "command": "runConfig.edit", "title": "Edit", "icon": "$(edit)" },
      { "command": "runConfig.delete", "title": "Delete", "icon": "$(trash)" },
      { "command": "runConfig.run", "title": "Run", "icon": "$(play)" },
      { "command": "runConfig.stop", "title": "Stop", "icon": "$(debug-stop)" },
      { "command": "runConfig.debug", "title": "Debug", "icon": "$(debug-alt)" },
      { "command": "runConfig.fix", "title": "Fix Invalid Configuration", "icon": "$(wrench)" },
      { "command": "runConfig.openFile", "title": "Open run.json", "icon": "$(go-to-file)" }
    ],
    "menus": {
      "view/title": [
        { "command": "runConfig.add", "when": "view == runConfigurations", "group": "navigation@1" },
        { "command": "runConfig.autoCreate", "when": "view == runConfigurations", "group": "navigation@2" },
        { "command": "runConfig.stopAll", "when": "view == runConfigurations && rcm.anyRunning", "group": "navigation@3" },
        { "command": "runConfig.refresh", "when": "view == runConfigurations", "group": "navigation@4" }
      ],
      "view/item/context": [
        { "command": "runConfig.run", "when": "view == runConfigurations && viewItem =~ /^configIdle(NoDebug)?$/", "group": "inline@1" },
        { "command": "runConfig.stop", "when": "view == runConfigurations && viewItem =~ /^configRunning(NoDebug)?$/", "group": "inline@1" },
        { "command": "runConfig.debug", "when": "view == runConfigurations && viewItem == configIdle", "group": "inline@2" },
        { "command": "runConfig.fix", "when": "view == runConfigurations && viewItem == configInvalid", "group": "inline@1" },
        { "command": "runConfig.openFile", "when": "view == runConfigurations && viewItem == configInvalid", "group": "inline@2" },
        { "command": "runConfig.edit", "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running|Invalid)(NoDebug)?$/", "group": "inline@3" },
        { "command": "runConfig.delete", "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running|Invalid)(NoDebug)?$/", "group": "inline@4" }
      ]
    }
  },
  "scripts": {
    "clean": "rimraf out media/webview",
    "build:extension": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "build": "npm run clean && npm run build:webview && npm run build:extension",
    "watch:extension": "node esbuild.config.mjs --watch",
    "watch:webview": "vite build --watch",
    "watch": "npm-run-all --parallel watch:extension watch:webview",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "dependencies": {
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^18.19.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.10",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
