{
  "name": "run-config-manager",
  "displayName": "Run Configuration Manager",
  "description": "IntelliJ-style run configurations for VS Code.",
  "version": "0.5.2",
  "publisher": "SebastianGross",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigbasti/run-config-manager.git"
  },
  "author": {
    "name": "Sebastian Gross",
    "email": "bigbasti@outlook.com"
  },
  "icon": "media/runconf.png",
  "keywords": [
    "run",
    "configuration",
    "manager",
    "intellij",
    "runner",
    "debugger",
    "tasks"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "runConfigManager",
          "title": "Run Configurations",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "runConfigManager": [
        {
          "id": "runConfigurations",
          "name": "Configurations",
          "contextualTitle": "Run Configurations"
        },
        {
          "id": "runConfigLaunchTasks",
          "name": "Launch & Tasks",
          "contextualTitle": "Run Configurations"
        }
      ]
    },
    "commands": [
      {
        "command": "runConfig.add",
        "title": "Add Run Configuration",
        "icon": "$(add)"
      },
      {
        "command": "runConfig.autoCreate",
        "title": "Auto-create Configurations",
        "icon": "$(sparkle)"
      },
      {
        "command": "runConfig.stopAll",
        "title": "Stop All Running",
        "icon": "$(stop-circle)"
      },
      {
        "command": "runConfig.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "runConfig.edit",
        "title": "Edit",
        "icon": "$(edit)"
      },
      {
        "command": "runConfig.clone",
        "title": "Clone",
        "icon": "$(copy)"
      },
      {
        "command": "runConfig.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "runConfig.reveal",
        "title": "Reveal Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "runConfig.run",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "runConfig.stop",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "runConfig.debug",
        "title": "Debug",
        "icon": "$(debug-alt)"
      },
      {
        "command": "runConfig.fix",
        "title": "Fix Invalid Configuration",
        "icon": "$(wrench)"
      },
      {
        "command": "runConfig.openFile",
        "title": "Open run.json",
        "icon": "$(go-to-file)"
      },
      {
        "command": "runConfig.viewNativeLaunch",
        "title": "View Launch JSON",
        "icon": "$(preview)"
      },
      {
        "command": "runConfig.viewNativeTask",
        "title": "View Task JSON",
        "icon": "$(preview)"
      },
      {
        "command": "runConfig.runNativeLaunch",
        "title": "Run Launch",
        "icon": "$(play)"
      },
      {
        "command": "runConfig.stopNativeLaunch",
        "title": "Stop Launch",
        "icon": "$(debug-stop)"
      },
      {
        "command": "runConfig.runNativeTask",
        "title": "Run Task",
        "icon": "$(play)"
      },
      {
        "command": "runConfig.stopNativeTask",
        "title": "Stop Task",
        "icon": "$(debug-stop)"
      },
      {
        "command": "runConfig.editNativeLaunch",
        "title": "Open launch.json",
        "icon": "$(edit)"
      },
      {
        "command": "runConfig.editNativeTask",
        "title": "Open tasks.json",
        "icon": "$(edit)"
      },
      {
        "command": "runConfig.viewDockerLogs",
        "title": "View Docker Logs",
        "icon": "$(output)"
      },
      {
        "command": "runConfig.openRunJson",
        "title": "Open run.json",
        "icon": "$(gear)"
      },
      {
        "command": "runConfig.buildAction.maven.clean",
        "title": "Maven: Clean",
        "icon": { "light": "media/icons/maven.svg", "dark": "media/icons/maven.svg" }
      },
      {
        "command": "runConfig.buildAction.maven.build",
        "title": "Maven: Build (package -DskipTests)",
        "icon": { "light": "media/icons/maven.svg", "dark": "media/icons/maven.svg" }
      },
      {
        "command": "runConfig.buildAction.maven.test",
        "title": "Maven: Test",
        "icon": { "light": "media/icons/maven.svg", "dark": "media/icons/maven.svg" }
      },
      {
        "command": "runConfig.buildAction.gradle.clean",
        "title": "Gradle: Clean",
        "icon": { "light": "media/icons/gradle-light.svg", "dark": "media/icons/gradle.svg" }
      },
      {
        "command": "runConfig.buildAction.gradle.build",
        "title": "Gradle: Build (assemble)",
        "icon": { "light": "media/icons/gradle-light.svg", "dark": "media/icons/gradle.svg" }
      },
      {
        "command": "runConfig.buildAction.gradle.test",
        "title": "Gradle: Test",
        "icon": { "light": "media/icons/gradle-light.svg", "dark": "media/icons/gradle.svg" }
      },
      {
        "command": "runConfig.npmAction.install",
        "title": "npm: Install",
        "icon": "media/icons/npm.svg"
      },
      {
        "command": "runConfig.npmAction.update",
        "title": "npm: Update",
        "icon": "media/icons/npm.svg"
      },
      {
        "command": "runConfig.npmAction.prune",
        "title": "npm: Prune",
        "icon": "media/icons/npm.svg"
      },
      {
        "command": "runConfig.findBlockingPorts",
        "title": "Find Blocking Ports",
        "icon": "$(plug)"
      },
      {
        "command": "runConfig.addToGroup",
        "title": "Add to Group…",
        "icon": "$(folder-opened)"
      },
      {
        "command": "runConfig.removeFromGroup",
        "title": "Remove from Group",
        "icon": "$(folder)"
      },
      {
        "command": "runConfig.runGroupSequential",
        "title": "Run All Sequentially",
        "icon": "$(run-all)"
      },
      {
        "command": "runConfig.runGroupParallel",
        "title": "Run All in Parallel",
        "icon": "$(run-above)"
      },
      {
        "command": "runConfig.renameGroup",
        "title": "Rename Group…",
        "icon": "$(edit)"
      },
      {
        "command": "runConfig.deleteGroup",
        "title": "Delete Group",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "runConfig.add",
          "when": "view == runConfigurations",
          "group": "navigation@1"
        },
        {
          "command": "runConfig.autoCreate",
          "when": "view == runConfigurations",
          "group": "navigation@2"
        },
        {
          "command": "runConfig.stopAll",
          "when": "view == runConfigurations && rcm.anyRunning",
          "group": "navigation@3"
        },
        {
          "command": "runConfig.refresh",
          "when": "view == runConfigurations",
          "group": "navigation@4"
        },
        {
          "command": "runConfig.openRunJson",
          "when": "view == runConfigurations",
          "group": "navigation@5"
        },
        {
          "command": "runConfig.add",
          "when": "view == runConfigurations",
          "group": "1_actions@1"
        },
        {
          "command": "runConfig.findBlockingPorts",
          "when": "view == runConfigurations",
          "group": "2_tools@1"
        },
        {
          "command": "runConfig.stopAll",
          "when": "view == runConfigurations && rcm.anyRunning",
          "group": "3_lifecycle@1"
        }
      ],
      "view/item/context": [
        {
          "command": "runConfig.run",
          "when": "view == runConfigurations && viewItem =~ /^configIdle(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "inline@1"
        },
        {
          "command": "runConfig.stop",
          "when": "view == runConfigurations && viewItem =~ /^configRunning(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "inline@1"
        },
        {
          "command": "runConfig.debug",
          "when": "view == runConfigurations && viewItem =~ /^configIdle(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "inline@2"
        },
        {
          "command": "runConfig.fix",
          "when": "view == runConfigurations && viewItem == configInvalid",
          "group": "inline@1"
        },
        {
          "command": "runConfig.openFile",
          "when": "view == runConfigurations && viewItem == configInvalid",
          "group": "inline@2"
        },
        {
          "command": "runConfig.edit",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running|Invalid)(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "inline@3"
        },
        {
          "command": "runConfig.clone",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "inline@4"
        },
        {
          "command": "runConfig.delete",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running|Invalid)(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "inline@5"
        },
        {
          "command": "runConfig.run",
          "when": "view == runConfigurations && viewItem =~ /^configIdle(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "1_run@1"
        },
        {
          "command": "runConfig.debug",
          "when": "view == runConfigurations && viewItem =~ /^configIdle(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "1_run@2"
        },
        {
          "command": "runConfig.stop",
          "when": "view == runConfigurations && viewItem =~ /^configRunning(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "1_run@3"
        },
        {
          "command": "runConfig.buildAction.maven.clean",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:maven(:grouped)?$/",
          "group": "2_build@1"
        },
        {
          "command": "runConfig.buildAction.maven.build",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:maven(:grouped)?$/",
          "group": "2_build@2"
        },
        {
          "command": "runConfig.buildAction.maven.test",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:maven(:grouped)?$/",
          "group": "2_build@3"
        },
        {
          "command": "runConfig.buildAction.gradle.clean",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:gradle(:grouped)?$/",
          "group": "2_build@1"
        },
        {
          "command": "runConfig.buildAction.gradle.build",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:gradle(:grouped)?$/",
          "group": "2_build@2"
        },
        {
          "command": "runConfig.buildAction.gradle.test",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:gradle(:grouped)?$/",
          "group": "2_build@3"
        },
        {
          "command": "runConfig.npmAction.install",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:npm(:grouped)?$/",
          "group": "2_build@1"
        },
        {
          "command": "runConfig.npmAction.update",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:npm(:grouped)?$/",
          "group": "2_build@2"
        },
        {
          "command": "runConfig.npmAction.prune",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?:npm(:grouped)?$/",
          "group": "2_build@3"
        },
        {
          "command": "runConfig.edit",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running|Invalid)(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "3_edit@1"
        },
        {
          "command": "runConfig.clone",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running)(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "3_edit@2"
        },
        {
          "command": "runConfig.delete",
          "when": "view == runConfigurations && viewItem =~ /^config(Idle|Running|Invalid)(NoDebug)?(:(maven|gradle|npm))?(:grouped)?$/",
          "group": "3_edit@3"
        },
        {
          "command": "runConfig.buildAction.maven.clean",
          "when": "view == runConfigurations && viewItem =~ /^depRcm(Idle|Running):maven$/",
          "group": "2_build@1"
        },
        {
          "command": "runConfig.buildAction.maven.build",
          "when": "view == runConfigurations && viewItem =~ /^depRcm(Idle|Running):maven$/",
          "group": "2_build@2"
        },
        {
          "command": "runConfig.buildAction.maven.test",
          "when": "view == runConfigurations && viewItem =~ /^depRcm(Idle|Running):maven$/",
          "group": "2_build@3"
        },
        {
          "command": "runConfig.buildAction.gradle.clean",
          "when": "view == runConfigurations && viewItem =~ /^depRcm(Idle|Running):gradle$/",
          "group": "2_build@1"
        },
        {
          "command": "runConfig.buildAction.gradle.build",
          "when": "view == runConfigurations && viewItem =~ /^depRcm(Idle|Running):gradle$/",
          "group": "2_build@2"
        },
        {
          "command": "runConfig.buildAction.gradle.test",
          "when": "view == runConfigurations && viewItem =~ /^depRcm(Idle|Running):gradle$/",
          "group": "2_build@3"
        },
        {
          "command": "runConfig.addToGroup",
          "when": "view == runConfigurations && viewItem =~ /^(config(Idle|Running)(NoDebug)?(:(maven|gradle|npm))?|docker(Idle|Running))$/",
          "group": "4_group@1"
        },
        {
          "command": "runConfig.removeFromGroup",
          "when": "view == runConfigurations && viewItem =~ /^(config(Idle|Running)(NoDebug)?(:(maven|gradle|npm))?|docker(Idle|Running)):grouped$/",
          "group": "4_group@1"
        },
        {
          "command": "runConfig.runGroupSequential",
          "when": "view == runConfigurations && viewItem == userGroup",
          "group": "1_run@1"
        },
        {
          "command": "runConfig.runGroupParallel",
          "when": "view == runConfigurations && viewItem == userGroup",
          "group": "1_run@2"
        },
        {
          "command": "runConfig.renameGroup",
          "when": "view == runConfigurations && viewItem == userGroup",
          "group": "2_edit@1"
        },
        {
          "command": "runConfig.deleteGroup",
          "when": "view == runConfigurations && viewItem == userGroup",
          "group": "2_edit@2"
        },
        {
          "command": "runConfig.runGroupSequential",
          "when": "view == runConfigurations && viewItem == userGroup",
          "group": "inline@1"
        },
        {
          "command": "runConfig.run",
          "when": "view == runConfigurations && viewItem =~ /^dockerIdle(:grouped)?$/",
          "group": "inline@1"
        },
        {
          "command": "runConfig.stop",
          "when": "view == runConfigurations && viewItem =~ /^dockerRunning(:grouped)?$/",
          "group": "inline@1"
        },
        {
          "command": "runConfig.viewDockerLogs",
          "when": "view == runConfigurations && viewItem =~ /^docker(Idle|Running)(:grouped)?$/",
          "group": "inline@2"
        },
        {
          "command": "runConfig.edit",
          "when": "view == runConfigurations && viewItem =~ /^docker(Idle|Running)(:grouped)?$/",
          "group": "inline@3"
        },
        {
          "command": "runConfig.clone",
          "when": "view == runConfigurations && viewItem =~ /^docker(Idle|Running)(:grouped)?$/",
          "group": "inline@4"
        },
        {
          "command": "runConfig.delete",
          "when": "view == runConfigurations && viewItem =~ /^docker(Idle|Running)(:grouped)?$/",
          "group": "inline@5"
        },
        {
          "command": "runConfig.runNativeLaunch",
          "when": "view == runConfigLaunchTasks && viewItem == nativeLaunchIdle",
          "group": "inline@1"
        },
        {
          "command": "runConfig.stopNativeLaunch",
          "when": "view == runConfigLaunchTasks && viewItem == nativeLaunchRunning",
          "group": "inline@1"
        },
        {
          "command": "runConfig.editNativeLaunch",
          "when": "view == runConfigLaunchTasks && viewItem =~ /^nativeLaunch/",
          "group": "inline@2"
        },
        {
          "command": "runConfig.runNativeTask",
          "when": "view == runConfigLaunchTasks && viewItem == nativeTaskIdle",
          "group": "inline@1"
        },
        {
          "command": "runConfig.stopNativeTask",
          "when": "view == runConfigLaunchTasks && viewItem == nativeTaskRunning",
          "group": "inline@1"
        },
        {
          "command": "runConfig.editNativeTask",
          "when": "view == runConfigLaunchTasks && viewItem =~ /^nativeTask/",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "clean": "rimraf out media/webview",
    "build:extension": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "build": "npm run clean && npm run build:webview && npm run build:extension",
    "watch:extension": "node esbuild.config.mjs --watch",
    "watch:webview": "vite build --watch",
    "watch": "npm-run-all --parallel watch:extension watch:webview",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "gen:icons": "node scripts/generate-icons.mjs",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "dependencies": {
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^18.19.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.10",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "simple-icons": "^16.17.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
